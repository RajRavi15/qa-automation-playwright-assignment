{
  "name": "playwright-framework",
  "version": "1.0.0",
  "type": "commonjs",
  "scripts": {
    "api:bdd": "cucumber-js src/features/api.feature --require src/steps/**/*.ts --require-module ts-node/register --format allure-cucumberjs/reporter",

  "ui:bdd": "cucumber-js src/features/**/*.feature --require src/steps/**/*.ts --require-module ts-node/register --tags \"@ui\" --format allure-cucumberjs/reporter",

  "ui:advanced": "cucumber-js src/features/advanced.feature --require src/steps/**/*.ts --require-module ts-node/register --format allure-cucumberjs/reporter",

  "allure:generate": "allure generate allure-results --clean -o allure-report",
  "allure:open": "allure open allure-report"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^13.0.0",
    "@playwright/test": "^1.60.0",
    "allure-commandline": "^2.42.1",
    "allure-cucumberjs": "^3.10.0",
    "allure-playwright": "^3.9.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@faker-js/faker": "^10.4.0"
  }
}
